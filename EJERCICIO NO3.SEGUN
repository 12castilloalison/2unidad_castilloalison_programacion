Algoritmo MENU
	DEFINIR PEDIDO Como entero
	Escribir "OPCIONES DE UN PEDIDO"
	Escribir "1.HAMBURGUESA"
	ESCRIBIR "2. PIZZA"
	Escribir "3. POLLO FRITO"
	Escribir "4.ENSALADA"
	
	ESCRIBIR " ELIGE TU PEDIDO DEL NO.1 AL NO.4;"
	LEER PEDIDO
	Segun PEDIDO Hacer
		1:
			ESCRIBIR "HAMBURGUESA"
		2:
			ESCRIBIR "PIZZA"
		3:
			ESCRIBIR "POLLO FRITO"
		4:
			ESCRIBIR "ENSALADA"
		De Otro Modo:
			ESCRIBIR " EL NUMERO QUE INGRESO NO ES VALIDO!!"
	Fin Segun
	
	
FinAlgoritmo
